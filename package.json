{
  "name": "catchat",
  "version": "0.1.0",
  "private": true,
  "author": "CatChat <dev@catchat.app>",
  "description": "Team collaboration messenger with threads, channels and lightning-fast command search",
  "license": "MIT",
  "main": "electron-main.js",
  "scripts": {
    "dev": "node scripts/dev-with-translator.mjs",
    "dev:next": "node scripts/dev-with-translator.mjs",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "migrate": "node scripts/apply-migration.mjs",
    "db:verify": "node scripts/verify-db.mjs",
    "supabase:setup": "node scripts/setup-supabase.mjs",
    "supabase:create-table": "node scripts/direct-create-table.mjs",
    "supabase:test": "node scripts/test-supabase-connection.mjs",
    "migrate:to-supabase": "node scripts/migrate-to-supabase.mjs",
    "translator:setup": "node scripts/setup-translator.mjs",
    "translator:start": "node scripts/start-translator.mjs",
    "translator:build": "node scripts/build-portable-translator.mjs",
    "desktop:dev": "electron .",
    "desktop:dev:hot": "node scripts/dev-desktop.mjs",
    "desktop:build": "pnpm run translator:build && next build --webpack && node -e \"const fs=require('fs');['.next/dev','.next/cache','.next/turbopack','dist','dist/**'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\" && electron-builder --win msi",
    "devtools": "cd dev-tools && node server.mjs"
  },
  "build": {
    "appId": "com.catchat.chat",
    "productName": "CatChat",
    "executableName": "catchat",
    "asar": true,
    "compression": "maximum",
    "asarUnpack": [
      "build/**",
      ".next/server/**",
      ".next/**/server/**",
      ".next/**",
      ".env.local"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CatChat",
      "warningsAsErrors": false,
      "upgradeCode": "{A1234567-BCDE-F012-3456-789ABCDEF012}"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "electron/**/*",
      "package.json",
      ".env.local",
      ".next/**/*",
      "!.next/dev/**",
      "!.next/cache/**",
      "!.next/turbopack/**",
      "app/**/*",
      "public/**/*",
      "build/**/*",
      "next.config.mjs",
      "next-env.d.ts",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!node_modules/**/*.md",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/__test__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/doc/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/coverage/**",
      "!node_modules/**/.github/**",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/changelog*",
      "!node_modules/**/CONTRIBUTING*",
      "!node_modules/**/History*",
      "!node_modules/**/history*",
      "!node_modules/**/.editorconfig",
      "!node_modules/**/.eslintrc*",
      "!node_modules/**/.prettierrc*",
      "!node_modules/**/.gitattributes",
      "!node_modules/**/.gitmodules",
      "!node_modules/**/.mailmap",
      "!node_modules/**/.yarn-integrity",
      "!node_modules/**/yarn.lock",
      "!node_modules/**/pnpm-lock.yaml",
      "!node_modules/**/package-lock.json",
      "!node_modules/**/tsconfig.json",
      "!node_modules/**/tsconfig.*.json",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.tsbuildinfo",
      "!node_modules/**/*.map",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.d.mts",
      "!node_modules/**/*.d.cts"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@supabase/supabase-js": "^2.110.7",
    "@swc/helpers": "^0.5.23",
    "@vercel/analytics": "1.6.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.1.4",
    "drizzle-orm": "^0.45.2",
    "emoji-picker-react": "^4.19.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.7.0",
    "shadcn": "^4.8.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  },
  "packageManager": "pnpm@10.16.1+sha512.0e155aa2629db8672b49e8475da6226aa4bdea85fdcdfdc15350874946d4f3c91faaf64cbdc4a5d1ab8002f473d5c3fcedcd197989cf0390f9badd3c04678706"
}

{
  "name": "catchat",
  "version": "0.3.0",
  "private": true,
  "author": "CatChat <dev@catchat.app>",
  "description": "Team collaboration messenger with threads, channels and lightning-fast command search",
  "license": "MIT",
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "migrate": "node scripts/apply-migration.mjs",
    "db:verify": "node scripts/verify-db.mjs",
    "supabase:setup": "node scripts/setup-supabase.mjs",
    "supabase:create-table": "node scripts/direct-create-table.mjs",
    "supabase:test": "node scripts/test-supabase-connection.mjs",
    "supabase:prefs-table": "node scripts/setup-preferences-table.mjs",
    "migrate:to-supabase": "node scripts/migrate-to-supabase.mjs",
    "desktop:dev": "electron .",
    "desktop:dev:hot": "node scripts/dev-desktop.mjs",
    "desktop:build": "node -e \"const fs=require('fs');['.next/dev','.next/cache','.next/turbopack','dist','dist/**'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\" && electron-builder --win",
    "desktop:publish": "node -e \"const fs=require('fs');['.next/dev','.next/cache','.next/turbopack','dist','dist/**'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\" && electron-builder --win --publish always && node scripts/publish-release.cjs",
    "release": "node scripts/release.cjs",
    "release-tool": "electron release-tool/electron-main.js",
    "release-tool:build": "cd release-tool && electron-builder --win",
    "devtools": "cd dev-tools && node server.mjs"
  },
  "build": {
    "appId": "com.catchat.chat",
    "productName": "CatChat",
    "executableName": "catchat",
    "asar": true,
    "compression": "maximum",
    "asarUnpack": [
      "build/**",
      ".env.production"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CatChat"
    },
    "publish": {
      "provider": "github",
      "owner": "coffee4433",
      "repo": "catchat"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "electron/**/*",
      "package.json",
      ".env.production",
      "build/**/*",
      "!build/argos-packages/**",
      "!build/translator-runtime/**"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@livekit/components-react": "^2.9.23",
    "@livekit/components-styles": "^1.2.0",
    "@supabase/supabase-js": "^2.110.7",
    "@swc/helpers": "^0.5.23",
    "@vercel/analytics": "1.6.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.1.4",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "emoji-picker-react": "^4.19.1",
    "framer-motion": "^12.42.2",
    "livekit-client": "^2.20.2",
    "livekit-server-sdk": "^2.17.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.7.0",
    "shadcn": "^4.8.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron-winstaller"
    ],
    "overrides": {
      "hono": "4.12.25"
    }
  },
  "packageManager": "pnpm@10.16.1+sha512.0e155aa2629db8672b49e8475da6226aa4bdea85fdcdfdc15350874946d4f3c91faaf64cbdc4a5d1ab8002f473d5c3fcedcd197989cf0390f9badd3c04678706"
}
